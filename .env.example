FOOTBALL_DATA_API_TOKEN=your_token_here

# Resend email verification. Required in production for real verification emails.
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM_EMAIL="World Cup Picks <verify@picks-football.com>"
AUTH_CLIENT_URL=http://127.0.0.1:5174/

# Local backend defaults. Leave HOST and PORT unset for local development:
# auth -> 127.0.0.1:8001, matches -> 127.0.0.1:8002, lobbies -> 127.0.0.1:8003.
# HOST=0.0.0.0
# PORT=10000
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://127.0.0.1:5174

# Production domain plan for picks-football.com:
# Main frontend: https://www.picks-football.com
# Auth frontend: https://auth.picks-football.com
# Auth API: https://auth-api.picks-football.com
# Matches API: https://matches-api.picks-football.com
# Lobbies API: https://lobbies-api.picks-football.com

# Render production examples. Set these per service in Render, not necessarily in local .env.
# ALLOWED_ORIGINS=https://www.picks-football.com,https://auth.picks-football.com
# AUTH_COOKIE_DOMAIN=.picks-football.com
# AUTH_COOKIE_SECURE=true
# AUTH_COOKIE_SAMESITE=Lax
# AUTH_DB_PATH=/var/data/auth.sqlite3
# AUTH_CLIENT_URL=https://auth.picks-football.com/
# LOBBIES_DB_PATH=/var/data/lobbies.sqlite3
# AUTH_SESSION_URL=https://auth-api.picks-football.com/session
# MATCHES_URL=https://matches-api.picks-football.com/matches

VITE_AUTH_CLIENT_URL=http://127.0.0.1:5174/
VITE_AUTH_API_URL=http://127.0.0.1:8001
VITE_MATCHES_API_URL=http://127.0.0.1:8002
VITE_LOBBIES_API_URL=http://127.0.0.1:8003
VITE_MAIN_APP_URL=http://127.0.0.1:5173/

# Vercel production examples.
# VITE_AUTH_CLIENT_URL=https://auth.picks-football.com/
# VITE_AUTH_API_URL=https://auth-api.picks-football.com
# VITE_MATCHES_API_URL=https://matches-api.picks-football.com
# VITE_LOBBIES_API_URL=https://lobbies-api.picks-football.com
# VITE_MAIN_APP_URL=https://www.picks-football.com/
